# DMTool v2.0 — Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development        # development | production
VERSION=2.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=file:dmtool.db
# Production (PostgreSQL):
# DATABASE_URL=postgres://user:password@host:5432/dmtool?sslmode=require

# ─── JWT RS256 Keys ───────────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the full PEM content below (including BEGIN/END lines).
# In .env, replace newlines with \n or use multiline values.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ─── AES-256-GCM Encryption (for OAuth token storage) ─────────────────────────
# Must be exactly 32 random bytes (64 hex chars or 32 ASCII chars).
ENCRYPTION_KEY=change-this-to-32-random-chars!!

# ─── CORS & Frontend ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Google OAuth 2.0 (Search Console) ────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Search Console API
# Redirect URI: http://localhost:8080/api/integrations/google/callback
GOOGLE_CLIENT_ID=812646610840-a42evq7sddodt43nul95srr9c8sug05p.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# ─── Meta (Facebook / Instagram) OAuth ────────────────────────────────────────
# Create at: https://developers.facebook.com
# Required scopes: pages_read_engagement, instagram_basic, instagram_manage_insights
# Redirect URI: http://localhost:8080/api/integrations/meta/callback
META_APP_ID=2350572068757768
META_APP_SECRET=a967af7a36cf95c61b7ed0e30b5bc6ea

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Without this key, Content AI returns 503 and InsightGenerator worker is skipped.
# The dashboard still works fully with auto-seeded data.
OPENAI_API_KEY=
