# DMTool Backend Configuration

PORT=8080
APP_ENV=development
VERSION=2.0.0
DATABASE_URL=file:dmtool.db
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Security (Important for local data encryption)
# Generate a 32-character random string for this
ENCRYPTION_KEY=6368616e67652074686973206c6174657221

# Meta (Facebook/Instagram) Integration
# 1. Go to https://developers.facebook.com/
# 2. Create an App -> Type: Consumer or Business
# 3. Add 'Instagram Basic Display' or 'Instagram Graph API'
META_APP_ID=1287665883571609
META_APP_SECRET=64a870844f028e299f9e1237fe51c465
META_PAGE_ACCESS_TOKEN=YOUR_META_PAGE_ACCESS_TOKEN

# Google Search Console Integration
# 1. Go to https://console.cloud.google.com/
# 2. Create a Project -> Enable 'Google Search Console API'
# 3. Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# AI Insights (Optional)
OPENAI_API_KEY=
